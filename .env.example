# OpenSearch (watsonx.data) – copy to .env and fill in. Use: source .env  (or use scripts/opensearch_curl.sh)
# Do not commit .env (it is in .gitignore).

OPENSEARCH_HOST=your-opensearch-host.lakehouse.ibmappdomain.cloud
OPENSEARCH_PORT=9200
OPENSEARCH_USER=your_username
OPENSEARCH_PASSWORD=your_password
OPENSEARCH_INDEX=spark_demo_documents

# IBM Cloud / watsonx.data
IBM_API_KEY=your_ibm_cloud_api_key
WXD_CRN=crn:v1:bluemix:public:lakehouse:ca-tor:a/ACCOUNT_ID:INSTANCE_ID::
SPARK_ENGINE_ID=spark16

# AWS S3 (for Spark artifact + PDF source)
S3_BUCKET=boreillyopensearch
S3_REGION=eu-north-1
S3_ENDPOINT=s3.eu-north-1.amazonaws.com
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
OPENAI_API_KEY=your_openai_api_key

# Optional: low-resource Spark profile (default already 1g/1g/1)
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=1g
SPARK_EXECUTOR_INSTANCES=1


# Optional: base URL with auth for curl (set after filling above, or use scripts/opensearch_curl.sh)
# OPENSEARCH_URL="https://${OPENSEARCH_USER}:${OPENSEARCH_PASSWORD}@${OPENSEARCH_HOST}:${OPENSEARCH_PORT}"
